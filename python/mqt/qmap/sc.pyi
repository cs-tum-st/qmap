    def total_fidelity(self, arg: float, /) -> None: ...
    @property
    def total_log_fidelity(self) -> float: ...
    @total_log_fidelity.setter
    def total_log_fidelity(self, arg: float, /) -> None: ...
    @property
    def swaps(self) -> int: ...
    @swaps.setter
