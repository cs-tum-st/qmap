    def single_qubit_gates(self) -> int: ...
    @single_qubit_gates.setter
    def single_qubit_gates(self, arg: int, /) -> None: ...
    @property
    def cnots(self) -> int: ...
    @cnots.setter
    def cnots(self, arg: int, /) -> None: ...
    @property
    def layers(self) -> int: ...
    @layers.setter
